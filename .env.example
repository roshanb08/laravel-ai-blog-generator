APP_NAME="Laravel AI Blog Generator"
APP_ENV=production
# Leave blank — automatically generated on first `docker compose up`
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (MySQL) ───────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=laravel-mysql
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# ── Cache & Sessions (Redis) ───────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=laravel-redis
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ── Blog API ───────────────────────────────────────────────────────────────────
# Internal Docker URL — the web container reaches the api container by service name.
# For local dev without Docker, change to http://localhost:8000
BLOG_API_URL=http://laravel-api:8000

# ── AI Blog Generator service (consumed by the `api` container) ────────────────
# The web container ignores these; they are forwarded via the shared env_file in compose.

# NewsAPI — free key at https://newsapi.org/register
NEWS_API_KEY=

# LLM provider: openrouter | openwebui
LLM_PROVIDER=openrouter

# OpenRouter (recommended — free models available at https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free
OPENROUTER_SITE_URL=https://your-site.com
OPENROUTER_SITE_NAME=Laravel AI Blog Generator

# OpenWebUI (alternative — self-hosted LLM)
# LLM_PROVIDER=openwebui
# OPENWEBUI_BASE_URL=https://your-openwebui-instance.com
# OPENWEBUI_API_KEY=
# OPENWEBUI_MODEL=gpt-4o

# LLM tuning
LLM_TIMEOUT=90
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
REQUEST_TIMEOUT=120

# Deduplication (SQLite, persisted in the laravel_ai_blog_data volume)
# Run `make reset-dedup` to clear this during testing if you get "0 unique articles" errors
DEDUP_DB_PATH=/data/dedup.db
DEDUP_TITLE_SIMILARITY_THRESHOLD=0.65
DEDUP_TTL_HOURS=48

# Response cache
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300

# Limits & logging
MAX_NEWS_FETCH=20
ENVIRONMENT=production

# ── Mail ───────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Filesystem ─────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

VITE_APP_NAME="${APP_NAME}"
